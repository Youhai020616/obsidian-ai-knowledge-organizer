{
	"name": "obsidian-ai-knowledge-organizer",
	"version": "0.1.1",
	"description": "Review-first AI knowledge organization for Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"docs:check": "node scripts/docs-check.mjs",
		"e2e:install": "node scripts/e2e-install-check.mjs",
		"beta:vault": "node scripts/create-beta-vault.mjs",
		"verify:all": "node scripts/verify-all.mjs",
		"release:check": "node scripts/release-check.mjs",
		"package:release": "node scripts/package-release.mjs",
		"release:notes": "node scripts/release-notes.mjs",
		"publish:preflight": "node scripts/github-publish-preflight.mjs",
		"publish:report": "node scripts/publish-report.mjs",
		"community:preflight": "node scripts/community-preflight.mjs",
		"community:entry": "node scripts/community-entry.mjs",
		"community:pr-body": "node scripts/community-pr-body.mjs"
	},
	"keywords": [
		"obsidian",
		"ai",
		"knowledge-management",
		"review-first",
		"pkm"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.0.15"
	}
}
